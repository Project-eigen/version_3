FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-this

# Local: SQLite is fine.
# Production (Render): use Supabase IPv4 POOLER only — not db.*.supabase.co
# Example:
# DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=sqlite:///dawaisathi.db

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/callback
FRONTEND_URL=http://localhost:5173

GEMINI_API_KEY=your-gemini-api-key

# Cloudinary — required in production (no local disk fallback when RENDER=true / FLASK_ENV=production)
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Telegram Bot (get token from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Public HTTPS backend URL (no trailing slash)
TELEGRAM_WEBHOOK_URL=https://your-tunnel-url.devtunnels.ms

# Web Push VAPID keys — run `python generate_vapid.py` to generate these
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_CLAIMS_EMAIL=admin@dawaisathi.com

# External cron (cron-job.org) → GET /api/notifications/trigger-check
# Required in production (RENDER=true or FLASK_ENV=production). Optional for local dev.
# Pass as header X-Cron-Secret or query ?cron_secret=
CRON_SECRET=generate-a-long-random-string
