FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-this

DATABASE_URL=sqlite:///dawaisathi.db

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/callback
FRONTEND_URL=http://localhost:5173

GEMINI_API_KEY=your-gemini-api-key

# Telegram Bot (get token from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Your public HTTPS backend URL — paste your VS Code tunnel URL here (no trailing slash)
TELEGRAM_WEBHOOK_URL=https://your-tunnel-url.devtunnels.ms

# Web Push VAPID keys — run `python generate_vapid.py` to generate these
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_CLAIMS_EMAIL=admin@dawaisathi.com
